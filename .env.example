# Neo4j Aura
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Google Drive
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_FOLDER_ID=

# Anthropic (personal)
ANTHROPIC_API_KEY=

# Anthropic (work / Foundry enterprise gateway)
ANTHROPIC_WORK_API_KEY=
ANTHROPIC_WORK_BASE_URL=

# SSL — corporate proxy / Zscaler
# Set SSL_VERIFY=false to disable certificate verification (quick fix)
# Or set SSL_CA_BUNDLE=/path/to/corporate-ca.pem to trust the corporate cert
SSL_VERIFY=true
SSL_CA_BUNDLE=

# App
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
